# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Docker Compose ile: postgres host adı container adıdır (postgres)
# Tek sunucu kurulumunda: localhost
DATABASE_URL=postgresql://voilee:voilee_secret@localhost:5432/voilee

# Docker Compose için ayrı kullanıcı/şifre (docker-compose.yml okur)
POSTGRES_USER=voilee
POSTGRES_PASSWORD=change-this-strong-db-password
POSTGRES_DB=voilee

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT session imzalama sırrı — üretimde openssl rand -hex 64 ile üret
JWT_SECRET=change-this-to-a-long-random-secret

# Yönetici paneli şifresi (/management-console için local login)
ADMIN_PASSWORD=change-this-strong-admin-password

# ─── 3 Katmanlı Mimari / CORS ─────────────────────────────────────────────────
# Frontend'in çalıştığı origin (Nginx'in dışa açık adresi).
# Birden fazla origin için virgülle ayır: https://voilee.com.tr,https://www.voilee.com.tr
CORS_ORIGIN=https://voilee.com.tr

# Backend sadece /api/* sunsun mu? (3 katmanlı mimari için false)
# Tek sunucu kurulumu için true yap.
SERVE_STATIC=false

# Backend portu
PORT=3000

# ─── OAuth (Manus platform — opsiyonel) ───────────────────────────────────────
# OAUTH_SERVER_URL ve VITE_APP_ID sadece Manus OAuth kullanıyorsan gerekli.
# Ayarlanmamışsa /management-console local şifre ile çalışır.
# OAUTH_SERVER_URL=
# VITE_APP_ID=
# OWNER_OPEN_ID=

# ─── AWS S3 (opsiyonel — dosya yükleme için) ──────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_BUCKET_NAME=

# ─── Analytics (opsiyonel) ────────────────────────────────────────────────────
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=
